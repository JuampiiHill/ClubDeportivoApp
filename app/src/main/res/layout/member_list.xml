<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/offwhite"
    tools:context=".MemberListActivity">

    <!-- Top rounded background with logo -->
    <LinearLayout
        android:id="@+id/topContainer"
        android:layout_width="match_parent"
        android:layout_height="280dp"
        android:background="@drawable/top_rounded_background"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:src="@drawable/logoclub"
            android:contentDescription="@string/logo_de_la_aplicacion" />
    </LinearLayout>

    <!-- Title -->
    <TextView
        android:id="@+id/titleMembers"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Socios"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        app:layout_constraintTop_toBottomOf="@id/topContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp" />

    <!-- Search bar -->
    <EditText
        android:id="@+id/inputSearchMember"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginTop="12dp"
        android:hint="Buscar socio por DNI"
        android:background="@drawable/search_background"
        android:paddingHorizontal="16dp"
        android:textColorHint="#888888"
        android:drawableStart="@drawable/ic_search"
        app:layout_constraintTop_toBottomOf="@id/titleMembers"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginHorizontal="24dp" />

    <!-- Hardcoded members list -->
    <LinearLayout
        android:id="@+id/membersList"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="12dp"
        android:layout_marginHorizontal="24dp"
        app:layout_constraintTop_toBottomOf="@id/inputSearchMember"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hillcoat, Juan Pablo\nEstado de cuota: \uD83D\uDFE2 Paga"
            android:background="@drawable/member_item_background"
            android:padding="12dp"
            android:textColor="@color/black"
            android:textSize="14sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Kalas, Jorge Adrián\nEstado de cuota: \uD83D\uDFE2 Paga"
            android:background="@drawable/member_item_background"
            android:padding="12dp"
            android:textColor="@color/black"
            android:textSize="14sp"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Leone, Milena Nadin\nEstado de cuota: \uD83D\uDFE2 Paga"
            android:background="@drawable/member_item_background"
            android:padding="12dp"
            android:textColor="@color/black"
            android:textSize="14sp"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Molina, María Julieta\nEstado de cuota: \uD83D\uDFE2 Paga"
            android:background="@drawable/member_item_background"
            android:padding="12dp"
            android:textColor="@color/black"
            android:textSize="14sp"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Rodríguez, Carlos Douglas\nEstado de cuota: \uD83D\uDFE2 Paga"
            android:background="@drawable/member_item_background"
            android:padding="12dp"
            android:textColor="@color/black"
            android:textSize="14sp"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Vega, José\nEstado de cuota: \uD83D\uDD34 Vencida"
            android:background="@drawable/member_item_background"
            android:padding="12dp"
            android:textColor="@color/black"
            android:textSize="14sp"
            android:layout_marginTop="8dp" />


    </LinearLayout>

    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="75dp"
        android:background="@color/fondo_oscuro2"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageButton
            android:id="@+id/btnInicio"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@color/fondo_oscuro2"
            android:contentDescription="@string/desc_btn_home"
            android:scaleType="fitXY"
            app:srcCompat="@drawable/btn_home_icon" />

        <ImageButton
            android:id="@+id/btnSocios"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@color/fondo_oscuro2"
            android:contentDescription="@string/desc_btn_socios"
            android:scaleType="fitXY"
            app:srcCompat="@drawable/btn_members_icon" />

        <ImageButton
            android:id="@+id/btnActividades"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@color/fondo_oscuro2"
            android:contentDescription="@string/desc_btn_actividades"
            android:scaleType="fitXY"
            app:srcCompat="@drawable/btn_activity_icon" />

        <ImageButton
            android:id="@+id/btnPagos"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@color/fondo_oscuro2"
            android:contentDescription="@string/desc_btn_pagos"
            android:scaleType="fitXY"
            app:srcCompat="@drawable/btn_pay_icon" />
    </LinearLayout>



</androidx.constraintlayout.widget.ConstraintLayout>
