<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/offwhite"
    tools:context=".ActivityListActivity">

    <!-- Header background -->
    <LinearLayout
        android:id="@+id/topContainer"
        android:layout_width="match_parent"
        android:layout_height="260dp"
        android:background="@drawable/top_rounded_background"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="180dp"
            android:layout_height="wrap_content"
            android:src="@drawable/logoclub"
            android:layout_marginTop="32dp"
            android:contentDescription="@string/logo_de_la_aplicacion" />
    </LinearLayout>

    <!-- Title -->
    <TextView
        android:id="@+id/titleActivity"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Actividades"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        app:layout_constraintTop_toBottomOf="@id/topContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />

    <!-- Search bar -->
    <EditText
        android:id="@+id/inputSearchActivity"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:hint="Buscar actividad"
        android:background="@drawable/search_background"
        android:paddingHorizontal="16dp"
        android:textColorHint="#888888"
        android:drawableStart="@drawable/ic_search"
        app:layout_constraintTop_toBottomOf="@id/titleActivity"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp"
        android:layout_marginHorizontal="24dp" />

    <!-- Lista de actividades -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/activityRecycler"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/inputSearchActivity"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="16dp" />

    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="75dp"
        android:background="@color/fondo_oscuro2"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageButton
            android:id="@+id/btnInicio"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@color/fondo_oscuro2"
            android:contentDescription="@string/desc_btn_home"
            android:scaleType="fitXY"
            app:srcCompat="@drawable/btn_home_icon" />

        <ImageButton
            android:id="@+id/btnSocios"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@color/fondo_oscuro2"
            android:contentDescription="@string/desc_btn_socios"
            android:scaleType="fitXY"
            app:srcCompat="@drawable/btn_members_icon" />

        <ImageButton
            android:id="@+id/btnActividades"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@color/fondo_oscuro2"
            android:contentDescription="@string/desc_btn_actividades"
            android:scaleType="fitXY"
            app:srcCompat="@drawable/btn_activity_icon" />

        <ImageButton
            android:id="@+id/btnPagos"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@color/fondo_oscuro2"
            android:contentDescription="@string/desc_btn_pagos"
            android:scaleType="fitXY"
            app:srcCompat="@drawable/btn_pay_icon" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
