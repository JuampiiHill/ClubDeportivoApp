<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/offwhite"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="32dp">

        <!-- Encabezado con fondo oscuro y logo -->
        <LinearLayout
            android:id="@+id/topcontainer"
            android:layout_width="0dp"
            android:layout_height="280dp"
            android:orientation="vertical"
            android:background="@drawable/top_rounded_background"
            android:gravity="center"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:id="@+id/logoclub"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:src="@drawable/logoclub"
                android:contentDescription="@string/logo_de_la_aplicacion"
                android:layout_marginTop="32dp" />
        </LinearLayout>

        <!-- Título -->
        <TextView
            android:id="@+id/titlePay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Abonar cuota"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            app:layout_constraintTop_toBottomOf="@id/topcontainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="16dp" />

        <!-- Campos de texto -->
        <EditText
            android:id="@+id/inputDocument"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Documento"
            android:backgroundTint="@color/gray"
            android:padding="12dp"
            app:layout_constraintTop_toBottomOf="@id/titlePay"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="16dp" />

        <EditText
            android:id="@+id/inputName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Nombre"
            android:backgroundTint="@color/gray"
            android:padding="12dp"
            app:layout_constraintTop_toBottomOf="@id/inputDocument"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="8dp" />

        <EditText
            android:id="@+id/inputLastName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Apellido"
            android:backgroundTint="@color/gray"
            android:padding="12dp"
            app:layout_constraintTop_toBottomOf="@id/inputName"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="8dp" />

        <EditText
            android:id="@+id/inputEmail"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="E-mail"
            android:inputType="textEmailAddress"
            android:backgroundTint="@color/gray"
            android:padding="12dp"
            app:layout_constraintTop_toBottomOf="@id/inputLastName"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="8dp" />

        <EditText
            android:id="@+id/inputAmount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Monto a abonar"
            android:inputType="numberDecimal"
            android:backgroundTint="@color/gray"
            android:padding="12dp"
            app:layout_constraintTop_toBottomOf="@id/inputEmail"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="8dp" />

        <!-- Métodos de pago -->
        <LinearLayout
            android:id="@+id/paymentOptions"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@id/inputAmount"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Efectivo" />

                <Switch
                    android:id="@+id/switchCash"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Tarjeta" />

                <Switch
                    android:id="@+id/switchCard"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>
        </LinearLayout>

        <!-- Botón de pagar -->
        <Button
            android:id="@+id/btnPay"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Pagar"
            android:backgroundTint="@color/red"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/paymentOptions"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="24dp"
            android:layout_marginHorizontal="64dp" />


        <LinearLayout
            android:id="@+id/bottomBar"
            android:layout_width="match_parent"
            android:layout_height="75dp"
            android:background="@color/fondo_oscuro2"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageButton
                android:id="@+id/btnInicio"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@color/fondo_oscuro2"
                android:contentDescription="@string/desc_btn_home"
                android:scaleType="fitXY"
                app:srcCompat="@drawable/btn_home_icon" />

            <ImageButton
                android:id="@+id/btnSocios"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@color/fondo_oscuro2"
                android:contentDescription="@string/desc_btn_socios"
                android:scaleType="fitXY"
                app:srcCompat="@drawable/btn_members_icon" />

            <ImageButton
                android:id="@+id/btnActividades"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@color/fondo_oscuro2"
                android:contentDescription="@string/desc_btn_actividades"
                android:scaleType="fitXY"
                app:srcCompat="@drawable/btn_activity_icon" />

            <ImageButton
                android:id="@+id/btnPagos"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@color/fondo_oscuro2"
                android:contentDescription="@string/desc_btn_pagos"
                android:scaleType="fitXY"
                app:srcCompat="@drawable/btn_pay_icon" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
